{
  "name": "sigil",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "predev": "npx tsx scripts/generate-partner-prompt.ts",
    "dev": "vite",
    "prebuild": "npx tsx scripts/generate-partner-prompt.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "genesis:export": "bash scripts/export_conversations.sh",
    "test:genesis": "python3 scripts/test_export_conversations.py",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.5",
    "@tauri-apps/api": "^2.3.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-store": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "codemirror": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.34.5",
    "sigil-core": "*"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.2"
  }
}
