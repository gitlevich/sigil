{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/main/crates/tauri-utils/schema.json",
  "productName": "Sigil",
  "version": "0.22.0",
  "identifier": "com.sigilengineering.sigil",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sigil",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gitlevich/sigil/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5ODBCMDlENEQxMkM4Q0EKUldUS3lCSk5uYkNBYVVMN2ZWWW9YKzhRaXVTb3Y0SnQwWHlVcEJmRDVQOXovRldaM2luRnYwcW0K"
    }
  }
}
